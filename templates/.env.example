# agentic-loop worker keys — copy to .env and fill in what you have.
# .env is gitignored. Scripts read this file from the project directory;
# keys are NEVER exported into your interactive Claude Code session.
#
# CRITICAL: never add an ANTHROPIC_API_KEY line here or export one in your
# shell. If ANTHROPIC_API_KEY is set, Claude Code bills your interactive
# session to the API instead of your Max subscription.

# Fable 5 worker — Claude API key, metered per token (separate from Max).
# Deliberately NOT named ANTHROPIC_API_KEY (see above).
FABLE_KEY=

# Sol (GPT-5.6) worker — OpenAI API key.
OPENAI_API_KEY=

# Cheap bulk workers — OpenRouter key.
OPENROUTER_API_KEY=

# Optional: default local model for call_ollama.sh (default: qwen3.5:4b)
# OLLAMA_MODEL=qwen3.5:4b

# Optional: override OpenRouter model aliases if the defaults go stale.
# OPENROUTER_MODEL_KIMI=moonshotai/kimi-k2
# OPENROUTER_MODEL_MINIMAX=minimax/minimax-m2
# OPENROUTER_MODEL_MIMO=xiaomi/mimo-v2
